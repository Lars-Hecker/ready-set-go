# Go API
DATABASE_URL=postgres://user:pass@localhost:5432/baseapp?sslmode=disable
JWT_SECRET=your-secret-key
PORT=8080

# Admin panel (Vite proxy target)
API_TARGET=http://localhost:8080

# S3 File Storage
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_URL_LIFETIME_MINUTES=15
